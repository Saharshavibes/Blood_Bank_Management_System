# Required secrets — empty by design. Compose interpolation fails fast if unset.
# JWT_SECRET_KEY: generate via `python -c "import secrets;print(secrets.token_urlsafe(48))"`.
# POSTGRES_PASSWORD: 32+ char random; rotate before flipping POSTGRES_BIND_HOST to 0.0.0.0.
POSTGRES_PASSWORD=
JWT_SECRET_KEY=

# Postgres
POSTGRES_DB=blood_bank
POSTGRES_USER=bbms_user
POSTGRES_PORT=5432
# Postgres host bind. Defaults to 127.0.0.1 (loopback only).
# Set to 0.0.0.0 to expose on LAN, or to a specific NIC IP for restricted exposure.
POSTGRES_BIND_HOST=127.0.0.1

# Backend
APP_NAME=Blood Bank Management API
APP_VERSION=1.0.0
ENVIRONMENT=production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:8080
# uvicorn worker count for the backend container; 2 is sufficient for a 16 GB host.
WEB_CONCURRENCY=2
BACKEND_PORT=8000

# Frontend
VITE_API_BASE_URL=/api/v1
FRONTEND_PORT=8080
