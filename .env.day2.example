# Deployment hook configuration used by .github/workflows/deploy.yml
# Set these as GitHub Actions repository secrets (not as a committed .env file).

# Production secret names (recommended)
RENDER_DEPLOY_HOOK_URL_PRODUCTION=
VERCEL_DEPLOY_HOOK_URL_PRODUCTION=
BACKEND_HEALTH_URL_PRODUCTION=https://your-backend.onrender.com/api/v1/health
BACKEND_AUTH_LOGIN_URL_PRODUCTION=https://your-backend.onrender.com/api/v1/auth/login
FRONTEND_URL_PRODUCTION=https://your-frontend.vercel.app

# Staging secret names (optional)
RENDER_DEPLOY_HOOK_URL_STAGING=
VERCEL_DEPLOY_HOOK_URL_STAGING=
BACKEND_HEALTH_URL_STAGING=https://your-staging-backend.onrender.com/api/v1/health
BACKEND_AUTH_LOGIN_URL_STAGING=https://your-staging-backend.onrender.com/api/v1/auth/login
FRONTEND_URL_STAGING=https://your-staging-frontend.vercel.app
